    ;; Pin 8  (GPIO8)  → AMP_SD (enable)
    ;; Pin 9  (GPIO1)  → VBAT_ADC
    ;; Pin 15 (GPIO15) → BUTTON
    ;; Pin 16 (GPIO16) → WS2812B_DIN
    ;; Pin 19 (GPIO19) → USB_DN
    ;; Pin 20 (GPIO20) → USB_DP
    ;; Pin GND         → GND
  )

