  (net_label "I2S_BCLK" (at 83.82 83.82 0) (effects (font (size 1.27 1.27))))
  (net_label "I2S_WS" (at 83.82 86.36 0) (effects (font (size 1.27 1.27))))
  (net_label "I2S_DIN" (at 83.82 88.9 0) (effects (font (size 1.27 1.27))))
  (net_label "I2S_DOUT" (at 160.02 88.9 0) (effects (font (size 1.27 1.27))))

  ;; Control
  (net_label "AMP_SD" (at 160.02 91.44 0) (effects (font (size 1.27 1.27))))
  (net_label "BUTTON" (at 160.02 101.6 0) (effects (font (size 1.27 1.27))))
  (net_label "WS2812_DIN" (at 160.02 104.14 0) (effects (font (size 1.27 1.27))))
  (net_label "VBAT_ADC" (at 160.02 68.58 0) (effects (font (size 1.27 1.27))))

  ;; USB
  (net_label "USB_DP" (at 160.02 106.68 0) (effects (font (size 1.27 1.27))))
  (net_label "USB_DN" (at 160.02 109.22 0) (effects (font (size 1.27 1.27))))

  ;; ============================================================
  ;; Wires (connections between components)
  ;; ============================================================

  ;; --- Power: USB → Charger → Battery → LDO → 3V3 ---
  ;; J1.VBUS → U5.VDD
  (wire (pts (xy 22.86 33.02) (xy 30.48 33.02)))
  ;; U5.VBAT → VBAT net → BT1(+) → U6.VIN
  (wire (pts (xy 45.72 40.64) (xy 50.8 40.64)))
  (wire (pts (xy 50.8 40.64) (xy 55.88 40.64)))
  ;; U6.VOUT → +3V3
  (wire (pts (xy 71.12 40.64) (xy 76.2 40.64)))

  ;; --- I2S Bus: Mics → ESP32 → Amp ---
  ;; U2.SCK → I2S_BCLK
  (wire (pts (xy 58.42 86.36) (xy 83.82 83.82)))
  ;; U2.WS → I2S_WS
  (wire (pts (xy 58.42 88.9) (xy 83.82 86.36)))
  ;; U2.SD → I2S_DIN
  (wire (pts (xy 58.42 91.44) (xy 83.82 88.9)))
  ;; U3.SCK → I2S_BCLK (shared)
  (wire (pts (xy 58.42 114.3) (xy 83.82 83.82)))
  ;; U3.WS → I2S_WS (shared)
  (wire (pts (xy 58.42 116.84) (xy 83.82 86.36)))
  ;; U3.SD → I2S_DIN (shared, wired-OR with L/R select)
  (wire (pts (xy 58.42 119.38) (xy 83.82 88.9)))

  ;; ESP32 GPIO4 → I2S_BCLK
  (wire (pts (xy 109.22 83.82) (xy 83.82 83.82)))
  ;; ESP32 GPIO5 → I2S_WS
  (wire (pts (xy 109.22 86.36) (xy 83.82 86.36)))
  ;; ESP32 GPIO6 → I2S_DIN
  (wire (pts (xy 109.22 88.9) (xy 83.82 88.9)))
  ;; ESP32 GPIO7 → I2S_DOUT → U4.DIN
  (wire (pts (xy 144.78 88.9) (xy 160.02 88.9)))
  (wire (pts (xy 160.02 88.9) (xy 198.12 88.9)))

  ;; I2S_BCLK → U4.BCLK
  (wire (pts (xy 83.82 83.82) (xy 198.12 83.82)))
  ;; I2S_WS → U4.LRCLK
  (wire (pts (xy 83.82 86.36) (xy 198.12 86.36)))

  ;; --- Amp → Speaker ---
  ;; U4.OUTP → SPK1+
  (wire (pts (xy 223.52 86.36) (xy 236.22 86.36)))
  ;; U4.OUTN → SPK1-
  (wire (pts (xy 223.52 91.44) (xy 236.22 91.44)))

  ;; --- AMP_SD: ESP32 GPIO8 → MAX98357A SD_MODE ---
  (wire (pts (xy 144.78 91.44) (xy 198.12 91.44)))

  ;; --- Button: GPIO15 → R5 pull-up + SW1 → GND ---
  (wire (pts (xy 144.78 101.6) (xy 200.66 139.7)))
  (wire (pts (xy 200.66 127.0) (xy 200.66 132.08)))   ;; R5 top → 3V3
  (wire (pts (xy 200.66 137.16) (xy 200.66 139.7)))    ;; R5 bottom → BUTTON net
  (wire (pts (xy 210.82 144.78) (xy 210.82 149.86)))   ;; SW1 → GND

  ;; --- LED: GPIO16 → WS2812B DIN ---
  (wire (pts (xy 144.78 104.14) (xy 200.66 119.38)))

  ;; --- VBAT ADC: GPIO1 → R1/R2 divider midpoint ---
  (wire (pts (xy 144.78 68.58) (xy 180.34 55.88)))
  ;; R1 top → VBAT
  (wire (pts (xy 167.64 55.88) (xy 162.56 55.88)))     ;; → VBAT label
  ;; R2 bottom → GND
  (wire (pts (xy 193.04 55.88) (xy 198.12 55.88)))     ;; → GND

  ;; --- USB Data: GPIO19/20 → USB-C D-/D+ ---
  (wire (pts (xy 109.22 106.68) (xy 22.86 43.18)))     ;; GPIO19 → USB D-
  (wire (pts (xy 109.22 109.22) (xy 22.86 45.72)))     ;; GPIO20 → USB D+

  ;; --- ESP32 EN: R7 pull-up + C9 reset delay ---
  (wire (pts (xy 106.68 60.96) (xy 109.22 66.04)))     ;; R7 top → 3V3
  (wire (pts (xy 106.68 71.12) (xy 109.22 71.12)))     ;; R7 bottom → EN
  (wire (pts (xy 106.68 76.2) (xy 106.68 78.74)))      ;; C9 bottom → GND

  ;; ============================================================
  ;; Text Annotations (section labels on schematic)
  ;; ============================================================

  (text "POWER SUPPLY\nUSB-C → MCP73831 (Charger) → LiPo → AP2112K (LDO) → 3.3V"
    (at 15.24 17.78 0) (effects (font (size 2.54 2.54) bold)))

  (text "MCU\nESP32-S3-MINI-1 (8MB Flash, 2MB PSRAM, WiFi+BLE)"
    (at 109.22 17.78 0) (effects (font (size 2.54 2.54) bold)))

  (text "AUDIO INPUT\nDual INMP441 MEMS Microphones (I2S, L+R)"
    (at 30.48 73.66 0) (effects (font (size 2.54 2.54) bold)))

  (text "AUDIO OUTPUT\nMAX98357A I2S Amp → 8ohm Speaker"
    (at 198.12 68.58 0) (effects (font (size 2.54 2.54) bold)))

  (text "USER INTERFACE\nWS2812B RGB LED + Tact Button"
    (at 198.12 109.22 0) (effects (font (size 2.54 2.54) bold)))

  (text "BATTERY MONITOR\n100K/100K divider → ADC (GPIO1)\nFull: 2.1V | Empty: 1.5V"
    (at 162.56 45.72 0) (effects (font (size 1.524 1.524))))

